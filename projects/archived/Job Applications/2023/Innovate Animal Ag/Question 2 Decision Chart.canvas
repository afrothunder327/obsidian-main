{
	"nodes":[
		{"id":"85ba23f9b4cf0801","type":"text","text":"Do they prioritize animal welfare?","x":-300,"y":-120,"width":280,"height":80,"color":"3"},
		{"id":"b420172147a2eb39","type":"text","text":"Are they committed to a commercialization strategy that will harm animals?","x":-560,"y":100,"width":300,"height":86,"color":"3"},
		{"id":"781204e09dd4740c","type":"text","text":"Have they pursued intellectual property for their invention?","x":-60,"y":100,"width":280,"height":100,"color":"3"},
		{"id":"3c037546cbe8f1c2","type":"text","text":"**QUESTION**","x":-919,"y":-110,"width":250,"height":60,"color":"3"},
