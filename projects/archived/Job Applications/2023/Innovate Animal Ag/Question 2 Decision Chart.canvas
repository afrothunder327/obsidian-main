		{"id":"430a7ae91f4ca983","type":"text","text":"Have they pursued an intellectual property claim?","x":-554,"y":396,"width":288,"height":82,"color":"3"},
		{"id":"02a9075a161d51b0","type":"text","text":"Have they pursued intellectual property for their invention?","x":-1203,"y":398,"width":300,"height":80,"color":"3"},
		{"id":"aa36e1c6b2001a96","type":"text","text":"IAA evaluates whether intended technology application is sufficiently high risk to justify sponsoring another researcher to make an incremental improvement that they can file a patent for.","x":-841,"y":678,"width":333,"height":182,"color":"1"},
		{"id":"e7ca2918df3577fb","type":"text","text":"Assist the researcher with obtaining intellectual property protection for their invention.","x":-112,"y":398,"width":225,"height":166,"color":"1"},
		{"id":"b2dd1308c320a323","type":"text","text":"Assist the researcher with obtaining intellectual property protection for their invention.","x":-1531,"y":654,"width":260,"height":140,"color":"1"},
		{"id":"e8fdda8627fcad7c","type":"text","text":"Connect with animal conscious investors who have been prepped with commercialization ideas that improve animal welfare.","x":-1203,"y":936,"width":300,"height":164,"color":"1"},
		{"id":"f507b976a34a505f","type":"text","text":"IAA introduces researcher to frameworks for thinking about commercialization strategies that can help animal welfare.\n","x":220,"y":568,"width":245,"height":180,"color":"1"},
		{"id":"f41b184ddc3646ff","x":220,"y":877,"width":250,"height":118,"color":"1","type":"text","text":"IAA connects researcher with animal conscious investors."},
